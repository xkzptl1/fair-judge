# ============================================================
# Fair Judge — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.
# ============================================================

# ── Supabase (required) ──────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...   # safe to expose; enforce access via RLS
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # server-side only — never expose to client

# ── LLM Provider (required for enrichment) ──────────────────
# Set LLM_PROVIDER to "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5       # optional; defaults to claude-haiku-4-5

# OpenAI (used when LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini             # optional; defaults to gpt-4o-mini

# ── Security (required in production) ───────────────────────
# Protects cron trigger routes. Vercel sends this automatically
# when CRON_SECRET is set in your Vercel project env vars.
CRON_SECRET=your-random-secret-here

# Protects /admin routes and sensitive API endpoints.
# Use a long random string. Shown as Basic Auth password in browser.
ADMIN_SECRET=your-admin-password-here
